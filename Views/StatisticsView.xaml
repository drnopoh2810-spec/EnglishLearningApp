<UserControl x:Class="EnglishLearningApp.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConv" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Statistics"
                              FontSize="28"
                              FontWeight="Bold" />
                    <Button Grid.Column="1"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Margin="0,0,8,0" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Loading Indicator -->
                <ProgressBar IsIndeterminate="True"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConv}}"
                            Margin="0,0,0,16" />

                <!-- Key Stats Grid -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Padding="16" Margin="4" UniformCornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding TotalSentences}" FontSize="28" FontWeight="Bold" />
                            <TextBlock Text="Total Sentences" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Padding="16" Margin="4" UniformCornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding MasteredSentences}" FontSize="28" FontWeight="Bold" Foreground="Green" />
                            <TextBlock Text="Mastered" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="2" Padding="16" Margin="4" UniformCornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding AverageMastery, StringFormat='{}{0:F1}%'}" FontSize="28" FontWeight="Bold" />
                            <TextBlock Text="Avg Mastery" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="3" Padding="16" Margin="4" UniformCornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentStreak}" FontSize="28" FontWeight="Bold" Foreground="Orange" />
                            <TextBlock Text="Day Streak" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Weekly Activity -->
                <materialDesign:Card Padding="20" Margin="0,0,0,16" UniformCornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Weekly Activity" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
                        <ItemsControl ItemsSource="{Binding WeeklyActivity}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="12,0" Width="50" HorizontalAlignment="Center">
                                        <Border Background="{DynamicResource PrimaryHueMidBrush}" 
                                               Height="{Binding BarHeight}" 
                                               MinHeight="4"
                                               CornerRadius="4"
                                               VerticalAlignment="Bottom"
                                               Opacity="0.8" />
                                        <TextBlock Text="{Binding Count}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,2" />
                                        <TextBlock Text="{Binding DayName}" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Group Statistics -->
                <materialDesign:Card Padding="20" Margin="0,0,0,16" UniformCornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Group Statistics" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Group" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Sentences" FontWeight="Bold" Margin="16,0,0,8" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Avg Mastery" FontWeight="Bold" Margin="16,0,0,8" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding GroupStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding GroupName}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SentenceCount}" Margin="16,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding AverageMastery, StringFormat='{}{0:F1}%'}" Margin="16,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Recent Reviews -->
                <materialDesign:Card Padding="20" Margin="0,0,0,16" UniformCornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Recent Reviews" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
                        <ItemsControl ItemsSource="{Binding RecentReviews}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding SentenceText}" TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="1" 
                                               Background="{Binding Rating, Converter={StaticResource RatingToBrushConverter}}" 
                                               CornerRadius="4" 
                                               Padding="6,2" 
                                               Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Rating}" FontSize="11" Foreground="White" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding MasteryAfter, StringFormat='{}{0:F0}%'}" Margin="8,0,0,0" />
                                        <TextBlock Grid.Column="3" Text="{Binding ReviewDate}" Opacity="0.5" FontSize="11" Margin="8,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
