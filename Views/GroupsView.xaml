<UserControl x:Class="EnglishLearningApp.Views.GroupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConv" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel - Groups List -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Groups"
                          FontSize="28"
                          FontWeight="Bold" />
                <Button Grid.Column="1"
                       Style="{StaticResource MaterialDesignRaisedButton}"
                       Command="{Binding AddNewCommand}"
                       Background="{DynamicResource PrimaryHueMidBrush}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Margin="0,0,8,0" />
                        <TextBlock Text="New" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Add/Edit Group Form -->
            <materialDesign:Card Grid.Row="1"
                                Padding="16"
                                Margin="0,0,0,16"
                                UniformCornerRadius="8"
                                Visibility="{Binding IsAddingNew, Converter={StaticResource BoolToVisibilityConv}}">
                <StackPanel>
                    <TextBlock Text="New Group"
                              FontWeight="Bold"
                              Margin="0,0,0,8" />
                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            materialDesign:HintAssist.Hint="Group Name *"
                            Text="{Binding NewGroupName}"
                            Margin="0,0,0,8" />
                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            materialDesign:HintAssist.Hint="Description"
                            Text="{Binding NewGroupDescription}"
                            Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                               Command="{Binding SaveNewCommand}"
                               Background="{DynamicResource PrimaryHueMidBrush}"
                               Margin="0,0,8,0">
                            <TextBlock Text="Save" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                               Command="{Binding CancelAddCommand}">
                            <TextBlock Text="Cancel" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1"
                                Padding="16"
                                Margin="0,0,0,16"
                                UniformCornerRadius="8"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConv}}">
                <StackPanel>
                    <TextBlock Text="Edit Group"
                              FontWeight="Bold"
                              Margin="0,0,0,8" />
                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            materialDesign:HintAssist.Hint="Group Name *"
                            Text="{Binding NewGroupName}"
                            Margin="0,0,0,8" />
                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            materialDesign:HintAssist.Hint="Description"
                            Text="{Binding NewGroupDescription}"
                            Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                               Command="{Binding SaveEditCommand}"
                               Background="{DynamicResource PrimaryHueMidBrush}"
                               Margin="0,0,8,0">
                            <TextBlock Text="Update" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                               Command="{Binding CancelAddCommand}">
                            <TextBlock Text="Cancel" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Groups List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                   Command="{Binding DataContext.NavigateToGroupsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   HorizontalAlignment="Stretch"
                                   Padding="12,8"
                                   Margin="0,2">
                                <Grid HorizontalAlignment="Stretch" Width="300">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding GroupName}" 
                                                  FontWeight="SemiBold"
                                                  HorizontalAlignment="Left" />
                                        <TextBlock Text="{Binding Description}" 
                                                  FontSize="11" 
                                                  Opacity="0.6"
                                                  TextTrimming="CharacterEllipsis"
                                                  HorizontalAlignment="Left" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" 
                                               Orientation="Horizontal"
                                               HorizontalAlignment="Right">
                                        <Border Background="{DynamicResource PrimaryHueMidBrush}" 
                                               CornerRadius="10" 
                                               Padding="8,2" 
                                               Margin="0,0,4,0">
                                            <TextBlock Text="{Binding SentenceCount}" 
                                                      FontSize="11"
                                                      Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" />
                                        </Border>
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                               Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}"
                                               Padding="4"
                                               ToolTip="Edit">
                                            <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" />
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                               Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}"
                                               Padding="4"
                                               Foreground="Red"
                                               ToolTip="Delete">
                                            <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Right Panel - Group Sentences -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                      Text="{Binding SelectedGroup.GroupName, FallbackValue='Select a group'}"
                      FontSize="24"
                      FontWeight="Bold"
                      Margin="0,0,0,16" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GroupSentences}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Padding="12" 
                                                Margin="0,0,0,8" 
                                                UniformCornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="{Binding EnglishSentence}"
                                              FontWeight="SemiBold"
                                              TextWrapping="Wrap"
                                              Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding ArabicTranslation}"
                                              FontSize="13"
                                              Opacity="0.7"
                                              TextWrapping="Wrap"
                                              FlowDirection="RightToLeft" />
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
