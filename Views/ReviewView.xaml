<UserControl x:Class="EnglishLearningApp.Views.ReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConv" />
    </UserControl.Resources>

    <Grid>
        <!-- Start Review Screen -->
        <Grid Visibility="{Binding IsReviewActive, Converter={StaticResource BoolToVisibilityConv}, ConverterParameter=Invert}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="Cards"
                                        Width="120"
                                        Height="120"
                                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                                        Opacity="0.5" />
                <TextBlock Text="Ready to Review?"
                          FontSize="32"
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          Margin="0,24,0,8" />
                <TextBlock Text="{Binding ReviewStatus}"
                          FontSize="16"
                          Opacity="0.6"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,32" />
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                       Command="{Binding StartReviewCommand}"
                       Background="{DynamicResource SecondaryHueMidBrush}"
                       Foreground="{DynamicResource SecondaryHueMidForegroundBrush}"
                       Padding="48,16"
                       FontSize="18">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Play" Margin="0,0,12,0" />
                        <TextBlock Text="Start Review Session" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Active Review Screen -->
        <Grid Visibility="{Binding IsReviewActive, Converter={StaticResource BoolToVisibilityConv}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Progress Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0"
                            Maximum="{Binding TotalCount}"
                            Value="{Binding CurrentIndex}"
                            Height="8"
                            Margin="0,0,16,0" />
                <TextBlock Grid.Column="1"
                          Text="{Binding ProgressText}"
                          FontSize="14"
                          FontWeight="SemiBold" />
            </Grid>

            <!-- Stats Bar -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="{DynamicResource MaterialDesignCardBackground}" 
                           CornerRadius="8" 
                           Padding="16,4" 
                           Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Check" Width="16" Height="16" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding ReviewsCompleted}" FontSize="14" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MaterialDesignCardBackground}" 
                           CornerRadius="8" 
                           Padding="16,4" 
                           Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TrendingUp" Width="16" Height="16" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding SessionMasteryChange, StringFormat='{}{0:F1}'}" FontSize="14" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Flashcard -->
            <materialDesign:Card Grid.Row="2"
                                Padding="40"
                                UniformCornerRadius="16"
                                Background="{DynamicResource MaterialDesignCardBackground}"
                                MouseLeftButtonDown="Card_Click">
                <Grid>
                    <!-- Front Side -->
                    <Grid Visibility="{Binding IsShowingFront, Converter={StaticResource BoolToVisibilityConv}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CurrentSentenceText}"
                                      FontSize="24"
                                      TextWrapping="Wrap"
                                      TextAlignment="Center"
                                      LineHeight="36"
                                      Margin="0,0,0,24" />
                            <TextBlock Text="Tap to reveal translation"
                                      FontSize="14"
                                      Opacity="0.4"
                                      FontStyle="Italic" />
                        </StackPanel>
                    </Grid>

                    <!-- Back Side -->
                    <Grid Visibility="{Binding IsShowingBack, Converter={StaticResource BoolToVisibilityConv}}">
                        <StackPanel VerticalAlignment="Center">
                            <!-- English -->
                            <TextBlock Text="{Binding CurrentSentenceText}"
                                      FontSize="18"
                                      TextWrapping="Wrap"
                                      Margin="0,0,0,16"
                                      Opacity="0.6" />

                            <!-- Arabic Translation -->
                            <TextBlock Text="{Binding CurrentTranslation}"
                                      FontSize="24"
                                      TextWrapping="Wrap"
                                      TextAlignment="Right"
                                      FlowDirection="RightToLeft"
                                      Foreground="{DynamicResource PrimaryHueMidBrush}"
                                      Margin="0,0,0,16" />

                            <!-- Notes -->
                            <TextBlock Text="{Binding CurrentNotes}"
                                      FontSize="14"
                                      TextWrapping="Wrap"
                                      Opacity="0.7"
                                      FontStyle="Italic"
                                      Margin="0,0,0,16"
                                      Visibility="{Binding CurrentNotes, Converter={StaticResource StringToVisibilityConverter}}" />

                            <!-- Meta Info -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border Background="{DynamicResource MaterialDesignToolBackground}" 
                                       CornerRadius="4" 
                                       Padding="8,2" 
                                       Margin="4">
                                    <TextBlock Text="{Binding CurrentDifficulty}" FontSize="11" />
                                </Border>
                                <Border Background="{Binding CurrentMastery, Converter={StaticResource MasteryToBrushConverter}}" 
                                       CornerRadius="4" 
                                       Padding="8,2" 
                                       Margin="4">
                                    <TextBlock Text="{Binding CurrentMastery, StringFormat='{}{0:F0}% Mastery'}" 
                                              FontSize="11"
                                              Foreground="White" />
                                </Border>
                                <Border Background="{DynamicResource MaterialDesignToolBackground}" 
                                       CornerRadius="4" 
                                       Padding="8,2" 
                                       Margin="4">
                                    <TextBlock Text="{Binding CurrentReviewCount, StringFormat='{}{0} reviews'}" FontSize="11" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </materialDesign:Card>

            <!-- Action Buttons -->
            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Audio and YouGlish -->
                <StackPanel Grid.Row="0" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12">
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                           Command="{Binding PlayAudioCommand}"
                           Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="VolumeHigh" Margin="0,0,8,0" />
                            <TextBlock Text="Play Audio" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                           Command="{Binding OpenYouGlishCommand}"
                           Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Video" Margin="0,0,8,0" />
                            <TextBlock Text="YouGlish" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                           Command="{Binding SkipCommand}"
                           Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="SkipNext" Margin="0,0,8,0" />
                            <TextBlock Text="Skip" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                           Command="{Binding EndSessionCommand}"
                           Margin="4"
                           Foreground="Red">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Close" Margin="0,0,8,0" />
                            <TextBlock Text="End Session" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Rating Buttons (only on back side) -->
                <StackPanel Grid.Row="1" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Center"
                           Visibility="{Binding IsShowingBack, Converter={StaticResource BoolToVisibilityConv}}">
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                           Command="{Binding RateAgainCommand}"
                           Background="#f44336"
                           Foreground="White"
                           Padding="24,12"
                           Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Close" Margin="0,0,8,0" />
                            <TextBlock Text="Again (1d)" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                           Command="{Binding RateHardCommand}"
                           Background="#ff9800"
                           Foreground="White"
                           Padding="24,12"
                           Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Alert" Margin="0,0,8,0" />
                            <TextBlock Text="Hard (3d)" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                           Command="{Binding RateGoodCommand}"
                           Background="#2196f3"
                           Foreground="White"
                           Padding="24,12"
                           Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Check" Margin="0,0,8,0" />
                            <TextBlock Text="Good (7d)" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                           Command="{Binding RateEasyCommand}"
                           Background="#4caf50"
                           Foreground="White"
                           Padding="24,12"
                           Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Star" Margin="0,0,8,0" />
                            <TextBlock Text="Easy (14d)" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Flip Prompt (only on front side) -->
                <TextBlock Grid.Row="1"
                          Text="Click card or press Space to flip"
                          FontSize="12"
                          Opacity="0.4"
                          HorizontalAlignment="Center"
                          Visibility="{Binding IsShowingFront, Converter={StaticResource BoolToVisibilityConv}}" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
