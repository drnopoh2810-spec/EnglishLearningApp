<UserControl x:Class="EnglishLearningApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:EnglishLearningApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConv" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="Dashboard"
                          FontSize="28"
                          FontWeight="Bold"
                          Margin="0,0,0,24" />

                <!-- Loading Indicator -->
                <ProgressBar IsIndeterminate="True"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConv}}"
                            Margin="0,0,0,16" />

                <!-- Stats Cards Row 1 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Total Sentences -->
                    <materialDesign:Card Grid.Column="0" 
                                        Padding="20" 
                                        Margin="4"
                                        UniformCornerRadius="8">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="BookOpenVariant" 
                                                    Width="32" 
                                                    Height="32"
                                                    Foreground="{DynamicResource PrimaryHueMidBrush}" />
                            <TextBlock Text="{Binding TotalSentences}"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      Margin="0,8,0,4" />
                            <TextBlock Text="Total Sentences"
                                      Opacity="0.7"
                                      FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Sentences Due -->
                    <materialDesign:Card Grid.Column="1" 
                                        Padding="20" 
                                        Margin="4"
                                        UniformCornerRadius="8"
                                        Background="{DynamicResource SecondaryHueMidBrush}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="ClockAlert" 
                                                    Width="32" 
                                                    Height="32"
                                                    Foreground="{DynamicResource SecondaryHueMidForegroundBrush}" />
                            <TextBlock Text="{Binding SentencesDueToday}"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      Foreground="{DynamicResource SecondaryHueMidForegroundBrush}"
                                      Margin="0,8,0,4" />
                            <TextBlock Text="Due Today"
                                      Foreground="{DynamicResource SecondaryHueMidForegroundBrush}"
                                      Opacity="0.8"
                                      FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Mastered -->
                    <materialDesign:Card Grid.Column="2" 
                                        Padding="20" 
                                        Margin="4"
                                        UniformCornerRadius="8">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="CheckCircle" 
                                                    Width="32" 
                                                    Height="32"
                                                    Foreground="Green" />
                            <TextBlock Text="{Binding MasteredSentences}"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      Margin="0,8,0,4" />
                            <TextBlock Text="Mastered"
                                      Opacity="0.7"
                                      FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Streak -->
                    <materialDesign:Card Grid.Column="3" 
                                        Padding="20" 
                                        Margin="4"
                                        UniformCornerRadius="8">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="Fire" 
                                                    Width="32" 
                                                    Height="32"
                                                    Foreground="Orange" />
                            <TextBlock Text="{Binding CurrentStreak}"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      Margin="0,8,0,4" />
                            <TextBlock Text="Day Streak"
                                      Opacity="0.7"
                                      FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Stats Cards Row 2 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Average Mastery -->
                    <materialDesign:Card Grid.Column="0" 
                                        Padding="20" 
                                        Margin="4"
                                        UniformCornerRadius="8">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="ChartLine" 
                                                    Width="32" 
                                                    Height="32"
                                                    Foreground="{DynamicResource PrimaryHueMidBrush}" />
                            <TextBlock Text="{Binding AverageMastery, StringFormat='{}{0:F1}%'}"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      Margin="0,8,0,4" />
                            <TextBlock Text="Average Mastery"
                                      Opacity="0.7"
                                      FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Learned -->
                    <materialDesign:Card Grid.Column="1" 
                                        Padding="20" 
                                        Margin="4"
                                        UniformCornerRadius="8">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="School" 
                                                    Width="32" 
                                                    Height="32"
                                                    Foreground="{DynamicResource PrimaryHueMidBrush}" />
                            <TextBlock Text="{Binding SentencesLearned}"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      Margin="0,8,0,4" />
                            <TextBlock Text="Sentences Learned"
                                      Opacity="0.7"
                                      FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Reviews Today -->
                    <materialDesign:Card Grid.Column="2" 
                                        Padding="20" 
                                        Margin="4"
                                        UniformCornerRadius="8">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="RotateRight" 
                                                    Width="32" 
                                                    Height="32"
                                                    Foreground="{DynamicResource PrimaryHueMidBrush}" />
                            <TextBlock Text="{Binding ReviewsToday}"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      Margin="0,8,0,4" />
                            <TextBlock Text="Reviews Today"
                                      Opacity="0.7"
                                      FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Weekly Activity Chart -->
                <materialDesign:Card Padding="20" 
                                    Margin="4,0,4,16"
                                    UniformCornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Weekly Activity"
                                  FontSize="18"
                                  FontWeight="Bold"
                                  Margin="0,0,0,16" />
                        
                        <ItemsControl ItemsSource="{Binding WeeklyActivity}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8,0" Width="40" HorizontalAlignment="Center">
                                        <Border Background="{DynamicResource PrimaryHueMidBrush}" 
                                               Height="{Binding BarHeight}" 
                                               MinHeight="4"
                                               CornerRadius="4"
                                               VerticalAlignment="Bottom"
                                               Opacity="0.8" />
                                        <TextBlock Text="{Binding Count}"
                                                  FontSize="11"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,4,0,2" />
                                        <TextBlock Text="{Binding DayName}"
                                                  FontSize="11"
                                                  Opacity="0.6"
                                                  HorizontalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Mastery Distribution -->
                <materialDesign:Card Padding="20" 
                                    Margin="4,0,4,16"
                                    UniformCornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Mastery Distribution"
                                  FontSize="18"
                                  FontWeight="Bold"
                                  Margin="0,0,0,16" />
                        
                        <ItemsControl ItemsSource="{Binding MasteryDistribution}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="16,0" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Count}"
                                                  FontSize="24"
                                                  FontWeight="Bold"
                                                  HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Range}"
                                                  FontSize="12"
                                                  Opacity="0.7"
                                                  HorizontalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Quick Actions -->
                <materialDesign:Card Padding="20" 
                                    Margin="4,0,4,16"
                                    UniformCornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Quick Actions"
                                  FontSize="18"
                                  FontWeight="Bold"
                                  Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                   Command="{Binding DataContext.NavigateToReviewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Background="{DynamicResource SecondaryHueMidBrush}"
                                   Foreground="{DynamicResource SecondaryHueMidForegroundBrush}"
                                   Padding="20,8"
                                   Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Play" Margin="0,0,8,0" />
                                    <TextBlock Text="Start Review" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Command="{Binding DataContext.NavigateToSentencesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Padding="20,8"
                                   Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Margin="0,0,8,0" />
                                    <TextBlock Text="Add Sentences" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Command="{Binding RefreshCommand}"
                                   Padding="20,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Margin="0,0,8,0" />
                                    <TextBlock Text="Refresh" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
